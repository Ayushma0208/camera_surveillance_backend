generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CameraStatus {
  connecting
  live
  stopped
  error
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  cameras Camera[]

  @@map("users")
}

model Camera {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  name      String       @db.VarChar(150)
  rtspUrl   String       @map("rtsp_url") @db.Text
  location  String       @db.VarChar(150)
  enabled   Boolean      @default(true)
  status    CameraStatus @default(stopped)
  createdAt DateTime     @default(now()) @map("created_at")

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts Alert[]
  stats  CameraStats?

  @@index([userId])
  @@index([status])
  @@map("cameras")
}

model Alert {
  id         String   @id @default(uuid()) @db.Uuid
  cameraId   String   @map("camera_id") @db.Uuid
  eventType  String   @map("event_type") @db.VarChar(100)
  confidence Float
  timestamp  DateTime
  imageUrl   String?  @map("image_url") @db.Text

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([cameraId, timestamp])
  @@map("alerts")
}

model CameraStats {
  cameraId              String   @id @map("camera_id") @db.Uuid
  fps                   Int
  detectionsPerMinute   Int      @map("detections_per_minute")
  updatedAt             DateTime @updatedAt @map("updated_at")

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@map("camera_stats")
}
