NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/camera_surveillance?schema=public
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
WORKER_BASE_URL=http://localhost:8001
WORKER_API_KEY=dev-worker-secret
CORS_ORIGIN=http://localhost:5173
RABBITMQ_URL=amqp://guest:guest@localhost:5672
CAMERA_COMMANDS_QUEUE=camera.commands
DETECTION_EVENTS_QUEUE=detection.events
ALERT_DEDUP_WINDOW_SECONDS=10
ALERT_RATE_LIMIT_PER_CAMERA_PER_MINUTE=6
